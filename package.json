{
  "name": "adp",
  "version": "0.1.0",
  "description": "ADP — Autonomous Development Pipeline: spec-to-code sprints with feedback control",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "bin": {
    "adp": "./dist/cli.js",
    "adp-i": "./dist/interactive.js",
    "adp-install": "./bin/install.mjs"
  },
  "files": [
    "SKILL.md",
    "README.md",
    "LICENSE",
    "templates",
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:standalone": "node scripts/build-standalone.mjs",
    "build:standalone:all": "node scripts/build-standalone.mjs --all",
    "start": "tsx src/ui/index.tsx",
    "start:legacy": "tsx src/interactive.ts",
    "cli": "tsx src/cli.ts",
    "adp:sensors": "tsx src/cli.ts sensors",
    "adp:status": "tsx src/cli.ts status",
    "adp:guides": "tsx src/cli.ts guides",
    "adp:start": "tsx src/cli.ts start",
    "adp:log": "tsx src/cli.ts log",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "ink": "^7.0.1",
    "ink-spinner": "^5.0.0",
    "ink-table": "^3.1.0",
    "react": "^19.2.5",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "eslint": "^9.19.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.0.5"
  }
}
